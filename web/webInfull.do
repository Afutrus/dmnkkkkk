<script type="text/javascript">
    (function () {
        function bindWebInfullLiteTracker() {
            if (!window.liteTracker) {
                return;
            }
            liteTracker.init({
                appId: '1010',
                pageVersion: '1.0.0',

                autoTrack: false,
                autoTrackClick: false,
                autoTrackDeclarative: false,
                batchReport: true,
                debug: false,
            });
            if (!liteTracker.initialized) {
                return;
            }
            var uidVal = $('#infullId').val();
            if (uidVal && String(uidVal).replace(/\s/g, '') !== '') {
                liteTracker.setUserId(String(uidVal));
            } else if (typeof userId !== 'undefined' && userId > 0) {
                liteTracker.setUserId(String(userId));
            }
            liteTracker.trackPageView({
                eventCode: 'web_infull'
            });

            function lt(code, extra) {
                if (extra && typeof extra === 'object') {
                    liteTracker.trackEvent(code, { extra: extra });
                } else {
                    liteTracker.trackEvent(code, {});
                }
            }

            $(document).on('click', '.btnDownloadTop', function () {
                if ($(this).is(':hidden') || $(this).css('display') === 'none') {
                    return;
                }
                lt('webinfull_top_domino_download_click', { href: this.getAttribute('href') || '' });
            });

            $(document).on('click', '#goldProductList > li', function () {
                var idx = $('#goldProductList > li').index(this);
                var cfg = (window.WebInfullData && WebInfullData.goldProductConfigs && WebInfullData.goldProductConfigs[idx]) || {};
                lt('webinfull_product_buy_click', {
                    tab: 'coin',
                    productId: cfg.productId,
                    displayName: cfg.displayName,
                    localPrice: cfg.localPrice,
                    costKey: cfg.costKey
                });
            });

            $(document).on('click', '#diamondProductList > li', function () {
                var idx = $('#diamondProductList > li').index(this);
                var cfg = (window.WebInfullData && WebInfullData.diamondProductConfigs && WebInfullData.diamondProductConfigs[idx]) || {};
