            if (paymentConfig.giftNum == 0) {
                return 0;
            }
            var rate = Math.round(paymentConfig.giftNum * 100 / productConfig.propNum);
            return rate;
        },
        getProductConfigMaxPercentPayment: function (productConfig, productPayments) {
            var maxPercent = 0;
            var maxPercentPayment = null;
            if (!productPayments || productPayments.length == 0) {
                return maxPercentPayment;
            }
            for (var i = 0; i < productPayments.length; i++) {
                var productPayment = productPayments[i];
                if (productPayment && productPayment.giftNum > 0) {
                    var tempPercent = Math.round(productPayment.giftNum * 100 / productConfig.propNum);
                    if (tempPercent > maxPercent) {
                        maxPercent = tempPercent;
                        maxPercentPayment = productPayment;
                    }
                }
            }
            return maxPercentPayment;
        },
        getProductConfigMinPercentPayment: function (productConfig, productPayments) {
            var minPercent = 0;
            var minPercentPayment = null;
            if (!productPayments || productPayments.length == 0) {
                return minPercentPayment;
            }
            for (var i = 0; i < productPayments.length; i++) {
                var productPayment = productPayments[i];
                if (productPayment && productPayment.giftNum > 0) {
                    var tempPercent = Math.round(productPayment.giftNum * 100 / productConfig.propNum);
                    if (minPercent == 0 || tempPercent < minPercent) {
                        minPercent = tempPercent;
                        minPercentPayment = productPayment;
                    }

