    upoint.onCanceled = function () {
        console.log('trx canceled');
    }

    function scrollToTop() {
        $('html, body').animate({scrollTop: 0}, 'slow');
    }

    function topGwDownLoad() {
        var topDownLoadUrl = $("#topDownLoadUrl").val();
        if (!topDownLoadUrl) {
            return;
        }
        if (!isInApp()) {
            var clickedAt = Date.now();
            OOPup.showLoading();
            var appUri = "dmnopen://open";
            window.location.href = appUri;

            setTimeout(function () {
                OOPup.hideLoading();
                if ((Date.now() - clickedAt) < 3200) {
                    window.location.href = topDownLoadUrl;
                }
            }, 3000);
        } else {
            window.location.href = topDownLoadUrl;
        }

    }


    function isInApp() {
        var userAgent = navigator.userAgent;
        if (userAgent.indexOf("myappwebview") > 0) {
            return true;
        }
        return false;
    }
