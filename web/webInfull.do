<script type="text/javascript">
    function tab(index, element) {
        $('.regList').hide();
        $('.regList' + index).show();
        $('.tab_top li').removeClass("active");
        $(element).addClass("active");
    }

    if (infullType > 0) {
        tab('2', this);
    }

    function goBack() {
        if (userId > 0) {
            window.location.href = "https://www.topbos.com";
            return;
        }
        var hostname = window.location.hostname;
        var rootDomainUrl = 'https://' + hostname;
        window.location.href = rootDomainUrl;
    }


