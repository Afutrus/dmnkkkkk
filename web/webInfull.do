                    tab: 'diamond',
                    productId: cfg.productId,
                    displayName: cfg.displayName,
                    localPrice: cfg.localPrice,
                    costKey: cfg.costKey
                });
            });

            $(document).on('click', '#giftFirstInfullProductList .exchangeBtn', function () {
                var $img = $(this).find('img').first();
                var imgSrc = $img.length > 0 ? $img.attr('src') : '';
                lt('webinfull_product_buy_click', {
                    tab: 'first_gift',
                    imgSrc: imgSrc
                });
            });

            $(document).on('click', '#giftActivityInfullProductList .recharge-holder', function (e) {
                if ($(e.target).closest('.switchBtn').length) {
                    return;
                }
                var $img = $(this).find('img').first();
                var imgSrc = $img.length > 0 ? $img.attr('src') : '';

                lt('webinfull_product_buy_click', {
                    tab: 'activity_gift',
                    imgSrc:imgSrc
                });
            });
        }

        if (window.jQuery) {
            $(bindWebInfullLiteTracker);
        } else {
            document.addEventListener('DOMContentLoaded', bindWebInfullLiteTracker);
        }
    })();
</script>
